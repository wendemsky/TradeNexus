# Local Docker Compose password (used by postgres + pgAdmin containers)
POSTGRES_PASSWORD=changeme_local_only

# Spring Boot backend — set this in backend-trade-nexus/.env
DATABASE_URL=postgresql://tn_user:changeme_local_only@localhost:5432/tradenexus

# Neon (cloud) — replace with your Neon connection string
# DATABASE_URL=postgresql://user:password@ep-xxx.region.neon.tech/tradenexus?sslmode=require

# Railway (cloud) — copy DATABASE_URL from Railway environment variables panel
# DATABASE_URL=postgresql://user:password@containers-xxx.railway.app:5432/tradenexus?sslmode=require
