# Apache Maven Wrapper startup shell script, version 3.3.1

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(pwd)}"

WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain

DOWNLOAD_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.1/maven-wrapper-3.3.1.jar"
PROPERTIES_FILE="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"
WRAPPER_URL=$(grep '^wrapperUrl=' "$PROPERTIES_FILE" 2>/dev/null | cut -d= -f2-)
[ -n "$WRAPPER_URL" ] && DOWNLOAD_URL="$WRAPPER_URL"

if [ ! -e "$WRAPPER_JAR" ]; then
    echo "Downloading $DOWNLOAD_URL to $WRAPPER_JAR"
    if command -v curl > /dev/null 2>&1; then
        curl -fsSL "$DOWNLOAD_URL" -o "$WRAPPER_JAR"
    elif command -v wget > /dev/null 2>&1; then
        wget -q -O "$WRAPPER_JAR" "$DOWNLOAD_URL"
    else
        echo "No curl or wget found. Please install curl and re-run." >&2
        exit 1
    fi
fi

MAVEN_JAVA_EXE="${JAVA_HOME:+$JAVA_HOME/bin/}java"

exec "$MAVEN_JAVA_EXE" \
  -classpath "$WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  $WRAPPER_LAUNCHER "$@"
